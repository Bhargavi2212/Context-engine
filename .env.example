# Mistral AI
MISTRAL_API_KEY=your-mistral-api-key

# LangSmith (optional in Phase 1, required from Phase 5)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your-langsmith-api-key
LANGCHAIN_PROJECT=context-engine-mistral

# Auth
JWT_SECRET_KEY=change-this-to-a-random-64-char-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database (local: ./data/context_engine.db; Docker sets DATABASE_PATH=/app/data/context_engine.db)
DATABASE_PATH=./data/context_engine.db

# Backend
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173
API_V1_PREFIX=/api/v1

# Frontend
VITE_API_BASE_URL=http://localhost:8000/api/v1
